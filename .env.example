# LifeBoard 环境变量
# 复制此文件为 .env 并填入真实值

# PostgreSQL 数据库
POSTGRES_USER=lifeboard
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=lifeboard

# 后端数据库连接
DATABASE_URL=postgresql+asyncpg://lifeboard:your_db_password_here@db:5432/lifeboard

# ezbookkeeping 数据源
EZBOOKKEEPING_BASE_URL=http://ezbookkeeping:8080
EZBOOKKEEPING_TOKEN=your_ezbookkeeping_api_token_here

# reward-todo 只读数据源
REWARD_TODO_BASE_URL=http://host.docker.internal:8088
REWARD_TODO_READONLY_TOKEN=replace-me
REWARD_TODO_APP_URL=http://127.0.0.1:8088
VITE_REWARD_TODO_APP_URL=http://127.0.0.1:8088
VITE_API_PROXY=http://backend:8000

# 定时同步间隔（分钟）
SYNC_INTERVAL_MINUTES=60
